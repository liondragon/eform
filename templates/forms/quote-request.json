{
  "id": "quote-request",
  "version": "1",
  "title": "Quote Request",
  "result_pages": {
    "success": {
      "title": "Your Message Was Sent!",
      "message": "Thank you for getting in touch! We will get back to you at the earliest convenience. Our average response time is 2 business days. If you require urgent assistance, please send us a text message at 720-900-5278.\n\nThe Flooring Artists Team"
    }
  },
  "email": {
    "to": "office@flooringartists.com",
    "subject": "Quote Request - {{field.name}}",
    "email_template": "default",
    "include_fields": [
      "name",
      "zip_us",
      "tel_us",
      "email",
      "message",
      "ip"
    ],
    "display_format_tel": "xxx-xxx-xxxx"
  },
  "fields": [
    {
      "key": "name",
      "type": "name",
      "label": "Your Name",
      "required": true,
      "placeholder": "Your Name",
      "autocomplete": "name"
    },
    {
      "key": "email",
      "type": "email",
      "label": "Email",
      "required": true,
      "placeholder": "Your eMail",
      "autocomplete": "email"
    },
    {
      "type": "row_group",
      "mode": "start",
      "tag": "div",
      "class": "columns_nomargins"
    },
    {
      "key": "tel_us",
      "type": "tel_us",
      "label": "Phone",
      "required": true,
      "placeholder": "Phone",
      "autocomplete": "tel"
    },
    {
      "key": "zip_us",
      "type": "zip_us",
      "label": "Zip",
      "required": true,
      "placeholder": "Project Zip Code",
      "autocomplete": "postal-code"
    },
    {
      "type": "row_group",
      "mode": "end"
    },
    {
      "key": "message",
      "type": "textarea",
      "label": "Message",
      "required": true,
      "placeholder": "Please describe your project and let us know if there is any urgency"
    }
  ],
  "submit_button_text": "Send Request"
}
